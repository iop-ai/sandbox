{
	"name": "iop-cli",
	"version": "4.7.2",
	"description": "Autonomous AI Coding Loop - Claude Code and Codex",
	"type": "module",
	"main": "dist/index.js",
	"bin": {
		"iop": "./bin.js"
	},
	"files": ["dist", "bin.js"],
	"scripts": {
		"version:generate": "node scripts/generate-version.js",
		"predev": "bun run version:generate",
		"dev": "bun run src/index.ts",
		"prebuild": "bun run version:generate",
		"build": "bun build src/index.ts --compile --minify --target=bun-darwin-arm64 --outfile dist/iop-darwin-arm64",
		"build:darwin-arm64": "bun build src/index.ts --compile --minify --target=bun-darwin-arm64 --outfile dist/iop-darwin-arm64",
		"build:darwin-x64": "bun build src/index.ts --compile --minify --target=bun-darwin-x64 --outfile dist/iop-darwin-x64",
		"build:linux-x64": "bun build src/index.ts --compile --minify --target=bun-linux-x64 --outfile dist/iop-linux-x64",
		"build:linux-arm64": "bun build src/index.ts --compile --minify --target=bun-linux-arm64 --outfile dist/iop-linux-arm64",
		"build:all": "bun run version:generate && bun run build:darwin-arm64 && bun run build:darwin-x64 && bun run build:linux-x64 && bun run build:linux-arm64",
		"check": "biome check --write .",
		"test": "bun test",
		"prepublishOnly": "bun run build:all"
	},
	"author": "",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/iop-ai/sandbox"
	},
	"dependencies": {
		"commander": "^13.0.0",
		"yaml": "^2.7.0",
		"simple-git": "^3.27.0",
		"@octokit/rest": "^21.0.0",
		"picocolors": "^1.1.0",
		"nanospinner": "^1.2.0",
		"zod": "^3.24.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@types/bun": "^1.1.0"
	},
	"engines": {
		"node": ">=18"
	}
}
